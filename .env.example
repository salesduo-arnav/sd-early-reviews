# --- Database Configuration (Local) ---
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydb

# --- Backend Configuration ---
PGHOST=localhost
PGPORT=5432
PGUSER=myuser
PGPASSWORD=mypassword
PGDATABASE=mydb

# App specific
NODE_ENV=development
PORT=3030
ADMIN_EMAILS=admin@salesduo.com,founder@salesduo.com,arnav@salesduo.com
MAX_NOTIFICATIONS_PER_USER=15
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=<SECRET_JWT>

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=<SECRET_EMAIL>
SMTP_PASS=<SECRET_PASSWORD>
SMTP_FROM=<SECRET_EMAIL>

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=<SECRET_CLIENT_ID>

# RAPID API
RAPID_API_KEY=<SECRET_RAPID_API_KEY>

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<SECRET_AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<SECRET_AWS_SECRET_ACCESS_KEY>
S3_BUCKET_NAME=<SECRET_S3_BUCKET_NAME>

# SP API Integration
AMZN_SP_APP_ID=<AMZN_SP_APP_ID>
AMZN_SP_CLIENT_ID=<AMZN_SP_CLIENT_ID>
AMZN_SP_CLIENT_SECRET=<AMZN_SP_CLIENT_SECRET>
AMZN_SP_REDIRECT_URI=http://localhost:3030/callback

# SP-API Verification
SP_API_ENCRYPTION_KEY=<32_BYTE_HEX_KEY>
SP_API_SANDBOX_MODE=false
SP_API_MOCK_MODE=false
REVIEW_VERIFICATION_MOCK_MODE=false

# Stripe Configuration
STRIPE_SECRET_KEY=<SECRET_STRIPE_SECRET_KEY>
STRIPE_WEBHOOK_SECRET=<SECRET_STRIPE_WEBHOOK_SECRET>

# Wise Configuration
WISE_API_TOKEN=<from Wise Business dashboard>
WISE_PROFILE_ID=<your Wise profile ID>
WISE_MODE=sandbox  # or 'live' for production
WISE_WEBHOOK_SECRET=<SECRET_WISE_WEBHOOK_SECRET>

# Exchange Rates API
OPEN_EXCHANGE_RATES_APP_ID=<SECRET_OPEN_EXCHANGE_RATES_APP_ID>
EXCHANGE_RATE_CACHE_HOURS=24

# --- Frontend Configuration ---
VITE_API_BASE_URL=/api
VITE_GOOGLE_CLIENT_ID=<SECRET_CLIENT_ID>
STRIPE_PUBLISHABLE_KEY=<SECRET_STRIPE_PUBLISHABLE_KEY>